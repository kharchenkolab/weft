#!/bin/sh
# weft-shim — site-side helper. POSIX sh + coreutils only; no daemon.
# Everything weft places on a site lives under one WEFT_ROOT; this script
# provides the primitives the controller composes: probe, detached run,
# status, log access, tree hashing, materialization, verified unpack.
set -eu

WEFT_SHIM_VERSION=6   # v6: list-tree file roots (fingerprint verb)
                      # v5: squashfs realization inputs (fuse/squashfuse/
                      # mksquashfs/userns/root fs); host-first glibc

json_bool() { if [ "$1" = "0" ]; then echo true; else echo false; fi; }

# sha256sum is coreutils; BSD/macOS ships shasum (perl) instead
sha256_of() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{print $1}'
    else
        shasum -a 256 "$1" | awk '{print $1}'
    fi
}

cmd_probe() {
    set +e   # a probe must survive whatever it finds; fallbacks are explicit
    os=$(uname -s | tr 'A-Z' 'a-z')
    arch=$(uname -m)
    host=$(hostname 2>/dev/null || echo unknown)
    cpus=$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
    mem_kb=$(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
    [ "${mem_kb:-0}" -gt 0 ] || mem_kb=$(( $(sysctl -n hw.memsize 2>/dev/null || echo 0) / 1024 ))
    mem_gb=$((mem_kb / 1048576))
    root="${WEFT_ROOT:-$HOME/.weft}"
    set -- $(df -Pk "$(dirname "$root")" 2>/dev/null | awk 'NR==2{print $4, $2}')
    free_gb=$(( ${1:-0} / 1048576 ))
    total_gb=$(( ${2:-0} / 1048576 ))
    net_check() {
        if command -v curl >/dev/null 2>&1; then
            curl -fsm "$1" -o /dev/null https://conda.anaconda.org 2>/dev/null
        elif command -v wget >/dev/null 2>&1; then
            wget -q -T "$1" -O /dev/null https://conda.anaconda.org 2>/dev/null
        else
            return 1
        fi
    }
    # one retry with a longer window: first-connection latency on a cold
    # host (VM network warm-up, slow first DNS) must not mislabel a
    # networked site as air-gapped for the life of its capability record
    if net_check 5 || net_check 8; then net=0; else net=1; fi
    apptainer_v=$(apptainer --version 2>/dev/null | awk '{print $NF}' || true)
    docker_ok=1; command -v docker >/dev/null 2>&1 && docker_ok=0
    sched=none
    command -v sbatch >/dev/null 2>&1 && sched=slurm
    command -v qsub  >/dev/null 2>&1 && [ "$sched" = none ] && sched=pbs
    modules=1; command -v modulecmd >/dev/null 2>&1 && modules=0
    [ -n "${LMOD_CMD:-}" ] && modules=0
    type module >/dev/null 2>&1 && modules=0
    rsync_ok=1; command -v rsync >/dev/null 2>&1 && rsync_ok=0
    # host truth first: compat layers (EESSI/Gentoo prefix on cvmfs) shadow
    # ldd in PATH and would report THEIR libc, not the one env binaries use
    LDD=ldd; [ -x /usr/bin/ldd ] && LDD=/usr/bin/ldd
    if $LDD --version 2>&1 | grep -qi musl; then
        glibc="musl"
    else
        glibc=$($LDD --version 2>/dev/null | head -1 | grep -o '[0-9][0-9.]*$' || echo "")
    fi
    # a broken driver prints its failure to STDOUT — filter to lines that
    # look like model names, or a garbage "model" lands in capabilities
    gpus=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null \
        | grep -v -i 'failed\|driver\|error\|no devices' | grep . | sort | uniq -c \
        | awk '{n=$1; $1=""; sub(/^ /,""); printf "%s{\"model\":\"%s\",\"count\":%d}", sep, $0, n; sep=","}' || true)
    cuda_driver=$(nvidia-smi 2>/dev/null | grep -o 'CUDA Version: [0-9.]*' | awk '{print $3}' | head -1 || true)
    # squashfs realization inputs: mounter (squashfuse_ll usually lives in
    # apptainer's libexec, not on PATH), builder, the fuse device, userns
    # usability (a REAL unshare smoke — sysctls lie), and the root's fs
    # type (fusermount3 refuses to mount over parallel filesystems)
    sq_fuse=1; [ -e /dev/fuse ] && sq_fuse=0
    sq_mount=""
    for c in squashfuse_ll squashfuse; do
        p=$(command -v "$c" 2>/dev/null) && [ -n "$p" ] && { sq_mount=$p; break; }
        [ -x "/usr/libexec/apptainer/bin/$c" ] && { sq_mount="/usr/libexec/apptainer/bin/$c"; break; }
    done
    sq_mk=$(command -v mksquashfs 2>/dev/null || true)
    if [ -z "$sq_mk" ]; then
        for p in /usr/sbin/mksquashfs /sbin/mksquashfs \
                 /usr/libexec/apptainer/bin/mksquashfs; do
            [ -x "$p" ] && { sq_mk=$p; break; }
        done
    fi
    sq_userns=1
    command -v unshare >/dev/null 2>&1 && unshare -rm true 2>/dev/null && sq_userns=0
    root_fs=""
    if [ "$os" = "linux" ]; then   # GNU stat only; BSD -f means "format"
        root_fs=$(stat -f -c %T "$root" 2>/dev/null \
                  || stat -f -c %T "$(dirname "$root")" 2>/dev/null || echo "")
    fi

    if [ -z "$gpus" ] && [ "$os" = "darwin" ] && [ "$arch" = "arm64" ]; then
        # Apple silicon: the integrated GPU is real and MPS-usable; the
        # model string says which backend so nobody mistakes it for CUDA
        chip=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "Apple silicon")
        gpus="{\"model\":\"$chip (Metal/MPS)\",\"count\":1}"
    fi
    # storage candidates: where could data/scratch live on this machine?
    # (existence, writability, free space; merged under user policy
    # controller-side — policy always wins, this only fills gaps)
    cands=""; csep=""
    uname_="${USER:-$(id -un 2>/dev/null || echo unknown)}"
    for d in "${HOME:-/tmp}" /scratch "/scratch/$uname_" \
             "/lscratch/$uname_" /tmp /dev/shm "/work/$uname_"; do
        [ -d "$d" ] || continue
        wr=1; [ -w "$d" ] && wr=0
        # free AND total: "how full is /scratch" needs the volume size —
        # free alone forced consumers to fabricate utilization
        set -- $(df -Pk "$d" 2>/dev/null | awk 'NR==2{print int($4/1048576), int($2/1048576)}')
        cfree=${1:-0}; ctotal=${2:-0}
        cands="$cands$csep{\"path\":\"$d\",\"writable\":$(json_bool $wr),\"free_gb\":$cfree,\"total_gb\":$ctotal}"
        csep=","
    done
    cat <<EOF
{"shim_version": $WEFT_SHIM_VERSION,
 "os": "$os", "arch": "$arch", "hostname": "$host",
 "cpus": $cpus, "mem_gb": $mem_gb, "glibc": "$glibc",
 "internet": $(json_bool $net),
 "runtimes": {"apptainer": "${apptainer_v:-}", "docker": $(json_bool $docker_ok), "rsync": $(json_bool $rsync_ok)},
 "scheduler": {"type": "$sched"},
 "module_system": $(json_bool $modules),
 "gpus": [${gpus:-}], "cuda_driver": "${cuda_driver:-}",
 "squashfs": {"dev_fuse": $(json_bool $sq_fuse), "squashfuse": "${sq_mount:-}",
              "mksquashfs": "${sq_mk:-}", "userns": $(json_bool $sq_userns),
              "root_fs": "${root_fs:-}"},
 "storage": {"weft_root": "$root", "free_gb": $free_gb, "total_gb": $total_gb,
             "candidates": [${cands:-}]}}
EOF
}

# run --dir JOBDIR ; expects JOBDIR/cmd.sh, optional JOBDIR/activate.sh
# Detached via setsid+nohup: survives the SSH session and controller.
cmd_run() {
    jobdir=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --dir) jobdir=$2; shift 2;;
            *) echo "run: unknown arg $1" >&2; exit 2;;
        esac
    done
    [ -n "$jobdir" ] && [ -f "$jobdir/cmd.sh" ] || { echo "run: need --dir with cmd.sh" >&2; exit 2; }
    jobdir=$(cd "$jobdir" && pwd)
    timer=""
    if command -v /usr/bin/time >/dev/null 2>&1; then
        if /usr/bin/time -v true 2>/dev/null; then
            timer="/usr/bin/time -v -o $jobdir/rusage"       # GNU: rss in kbytes
        elif /usr/bin/time -l -o /dev/null true 2>/dev/null; then
            timer="/usr/bin/time -l -o $jobdir/rusage"       # BSD: rss in bytes
        fi
    fi
    # backgrounding under a non-interactive shell leaves SIGINT ignored and
    # exec inherits that — interpreters would be un-interruptible. Reset it.
    sigreset=""
    env --default-signal=INT true 2>/dev/null && sigreset="env --default-signal=INT,HUP"
    if [ -z "$sigreset" ] && command -v perl >/dev/null 2>&1; then
        # BSD env has no --default-signal; perl resets INT/HUP for the
        # command subtree only (the runner must keep ignoring INT, or a
        # group interrupt would kill it before it writes the exit record)
        sigreset="perl -e '\$SIG{INT}=\"DEFAULT\"; \$SIG{HUP}=\"DEFAULT\"; exec @ARGV or die' --"
    fi
    cat > "$jobdir/runner.sh" <<EOF
#!/bin/sh
# squashfs envs on userns sites: the whole job runs in its own
# user+mount namespace — activation's lazy mount lands there and
# vanishes with the job (no epilogues, no stale mounts)
if [ -f "$jobdir/ns" ] && [ -z "\$WEFT_NS" ] \\
   && command -v unshare >/dev/null 2>&1 && unshare -rm true 2>/dev/null; then
    WEFT_NS=1 exec unshare -rm "\$0" "\$@"
fi
# conda activation hooks may contain bashisms — prefer bash when present
if [ -z "\$WEFT_BASH" ] && command -v bash >/dev/null 2>&1; then
    WEFT_BASH=1 exec bash "\$0" "\$@"
fi
cd "$jobdir"
echo \$\$ > pid.real
hostname > node 2>/dev/null || true
[ -f activate.sh ] && . ./activate.sh
start=\$(date +%s)
$timer $sigreset sh cmd.sh >> log 2>&1
rc=\$?
end=\$(date +%s)
echo "\$((end - start))" > wall_s
echo "\$rc" > exit_code.tmp && mv exit_code.tmp exit_code
EOF
    chmod +x "$jobdir/runner.sh"
    : > "$jobdir/log"
    if command -v setsid >/dev/null 2>&1; then
        nohup setsid sh "$jobdir/runner.sh" </dev/null >/dev/null 2>&1 &
    elif command -v perl >/dev/null 2>&1; then
        # no setsid(1) (macOS/BSD): perl's POSIX::setsid still gives the
        # runner its own session+pgid so cancel/interrupt group-kill -pid.
        # Signals are NOT reset here: the runner must keep INT ignored
        # (as under linux backgrounding) to survive a group interrupt and
        # write the exit record; $sigreset handles the command subtree.
        nohup perl -MPOSIX -e \
            'POSIX::setsid(); exec "sh", @ARGV or die' \
            "$jobdir/runner.sh" </dev/null >/dev/null 2>&1 &
    else
        # last resort: survives the session, but cancel's group-kill
        # degrades to the runner process only
        nohup sh "$jobdir/runner.sh" </dev/null >/dev/null 2>&1 &
    fi
    echo $! > "$jobdir/pid"
    echo "{\"started\": true, \"pid\": $(cat "$jobdir/pid")}"
}

# alive PID REF_FILE — is PID our process? kill -0 alone lies after a
# reboot (pid namespaces reset, pids recycle). Guards, where /proc exists:
# a pid recorded before the last boot is dead; a process that started
# measurably later than the pid file was written is a reused pid.
alive() {
    a_pid=$1; a_ref=$2
    kill -0 "$a_pid" 2>/dev/null || return 1
    [ -r /proc/stat ] || return 0
    btime=$(awk '/^btime/{print $2}' /proc/stat 2>/dev/null)
    [ -n "$btime" ] || return 0
    ref_t=$(stat -c %Y "$a_ref" 2>/dev/null || echo 0)
    [ "$ref_t" -gt 0 ] || return 0
    [ "$ref_t" -lt "$btime" ] && return 1
    if [ -r "/proc/$a_pid/stat" ]; then
        clk=$(getconf CLK_TCK 2>/dev/null || echo 100)
        st=$(sed 's/^[^)]*) //' "/proc/$a_pid/stat" 2>/dev/null | awk '{print $20}')
        case "$st" in ''|*[!0-9]*) return 0;; esac
        pstart=$((btime + st / clk))
        [ $((pstart - ref_t)) -gt 5 ] && return 1
    fi
    return 0
}

status_of() {
    jobdir=$1
    if [ ! -d "$jobdir" ]; then
        echo '{"state": "missing"}'; return
    fi
    if [ -f "$jobdir/exit_code" ]; then
        rc=$(cat "$jobdir/exit_code")
        wall=$(cat "$jobdir/wall_s" 2>/dev/null || echo 0)
        # GNU time -v: "Maximum resident set size (kbytes): N" (N last);
        # BSD time -l: "N  maximum resident set size" (bytes first)
        rss_kb=$(awk '/[Mm]aximum resident set/{if ($NF ~ /^[0-9]+$/) print $NF; else print int($1/1024)}' \
                 "$jobdir/rusage" 2>/dev/null || echo 0)
        echo "{\"state\": \"exited\", \"exit_code\": $rc, \"wall_s\": $wall, \"max_rss_kb\": ${rss_kb:-0}}"
        return
    fi
    # pid.real is written by the runner itself; the setsid wrapper pid can
    # exit immediately on some platforms, so it is only a fallback
    ref="$jobdir/pid.real"
    [ -f "$ref" ] || ref="$jobdir/pid"
    pid=$(cat "$jobdir/pid.real" 2>/dev/null || cat "$jobdir/pid" 2>/dev/null || echo "")
    if [ -n "$pid" ] && alive "$pid" "$ref"; then
        echo "{\"state\": \"running\", \"pid\": $pid}"
    elif [ -n "$pid" ]; then
        # no live pid and no exit_code: either truly dead, just-exited (the
        # exit_code rename is in flight), or just-started (pid.real pending)
        sleep 1
        if [ -f "$jobdir/exit_code" ]; then
            status_of "$jobdir"
        else
            p2=$(cat "$jobdir/pid.real" 2>/dev/null || echo "$pid")
            ref2="$jobdir/pid.real"; [ -f "$ref2" ] || ref2="$jobdir/pid"
            if [ -n "$p2" ] && alive "$p2" "$ref2"; then
                echo "{\"state\": \"running\", \"pid\": $p2}"
            else
                echo '{"state": "lost"}'
            fi
        fi
    else
        echo '{"state": "not_started"}'
    fi
}

cmd_status() {
    jobdir=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --dir) jobdir=$2; shift 2;;
            *) echo "status: unknown arg $1" >&2; exit 2;;
        esac
    done
    status_of "$jobdir"
}

# status-batch: job dirs on stdin (one per line), one JSON per line out:
# {"dir": "<dir>", ...status}. One invocation covers every job on the host.
cmd_status_batch() {
    while IFS= read -r d; do
        [ -n "$d" ] || continue
        s=$(status_of "$d")
        printf '{"dir": "%s", %s\n' "$d" "${s#\{}"
    done
}

cmd_tail() {
    file=""; lines=100
    while [ $# -gt 0 ]; do
        case "$1" in
            --file) file=$2; shift 2;;
            --lines) lines=$2; shift 2;;
            *) echo "tail: unknown arg $1" >&2; exit 2;;
        esac
    done
    [ -f "$file" ] && tail -n "$lines" "$file" || true
}

# read-from --file F --offset N --max M : incremental log follow
cmd_read_from() {
    file=""; offset=0; max=65536
    while [ $# -gt 0 ]; do
        case "$1" in
            --file) file=$2; shift 2;;
            --offset) offset=$2; shift 2;;
            --max) max=$2; shift 2;;
            *) echo "read-from: unknown arg $1" >&2; exit 2;;
        esac
    done
    [ -f "$file" ] || exit 0
    tail -c +$((offset + 1)) "$file" | head -c "$max"
}

cmd_head() {
    file=""; bytes=4096
    while [ $# -gt 0 ]; do
        case "$1" in
            --file) file=$2; shift 2;;
            --bytes) bytes=$2; shift 2;;
            *) echo "head: unknown arg $1" >&2; exit 2;;
        esac
    done
    [ -f "$file" ] && head -c "$bytes" "$file" || true
}

# list-tree --root R [--hash-under BYTES] [--max N] : TSV of
# path, bytes, mtime[, sha256]. Stat-only by default (an inventory
# receipt, not an integrity pass); hashes only files <= the threshold
# when asked. Total count on stderr as '#total <n>' for truncation
# honesty. Paths with newlines are skipped by construction (find|read).
cmd_list_tree() {
    root=""; hash_under=0; maxn=5000
    while [ $# -gt 0 ]; do
        case "$1" in
            --root) root=$2; shift 2;;
            --hash-under) hash_under=$2; shift 2;;
            --max) maxn=$2; shift 2;;
            *) echo "list-tree: unknown arg $1" >&2; exit 2;;
        esac
    done
    if [ -f "$root" ]; then
        # file root: one row at "." — same convention as hash-tree
        if stat -c %s "$root" >/dev/null 2>&1; then
            set -- $(stat -c '%s %Y' "$root")
        else
            set -- $(stat -f '%z %m' "$root")
        fi
        sz=${1:-0}; mt=${2:-0}; h=""
        if [ "$hash_under" -gt 0 ] && [ "$sz" -le "$hash_under" ]; then
            h=$(sha256_of "$root")
        fi
        printf '#total 1\n' >&2
        printf '.\t%s\t%s\t%s\n' "$sz" "$mt" "$h"
        return 0
    fi
    [ -d "$root" ] || { echo "list-tree: no such dir: $root" >&2; exit 2; }
    root=$(cd "$root" && pwd)
    if stat -c %s "$root" >/dev/null 2>&1; then st=gnu; else st=bsd; fi
    total=$(cd "$root" && find . -type f 2>/dev/null | wc -l | tr -d ' ')
    printf '#total %s\n' "$total" >&2
    ( cd "$root" && find . -type f 2>/dev/null | sed 's|^\./||' \
        | LC_ALL=C sort | head -n "$maxn" ) | \
    while IFS= read -r p; do
        full="$root/$p"
        if [ "$st" = gnu ]; then
            set -- $(stat -c '%s %Y' "$full" 2>/dev/null || echo 0 0)
        else
            set -- $(stat -f '%z %m' "$full" 2>/dev/null || echo 0 0)
        fi
        sz=${1:-0}; mt=${2:-0}
        h=""
        if [ "$hash_under" -gt 0 ] && [ "$sz" -le "$hash_under" ]; then
            h=$(sha256_of "$full")
        fi
        printf '%s\t%s\t%s\t%s\n' "$p" "$sz" "$mt" "$h"
    done
}

# hash-tree --root R [--rel] : TSV of kind, path, exec, size, sha256/target
cmd_hash_tree() {
    root=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --root) root=$2; shift 2;;
            *) echo "hash-tree: unknown arg $1" >&2; exit 2;;
        esac
    done
    # a FILE root is a single-artifact output (one figure, one table):
    # one row, path "." — a directory walk can never emit a bare "."
    if [ -f "$root" ] && [ ! -d "$root" ]; then
        x=0; [ -x "$root" ] && x=1
        sz=$(wc -c < "$root" | tr -d ' ')
        h=$(sha256_of "$root")
        printf 'file\t.\t%s\t%s\t%s\n' "$x" "$sz" "$h"
        return 0
    fi
    [ -d "$root" ] || { echo "hash-tree: no such file or directory: $root" >&2; exit 2; }
    root=$(cd "$root" && pwd)
    ( cd "$root" && find . \( -type f -o -type l \) | sed 's|^\./||' | LC_ALL=C sort ) | \
    while IFS= read -r p; do
        full="$root/$p"
        if [ -L "$full" ]; then
            printf 'link\t%s\t0\t0\t%s\n' "$p" "$(readlink "$full")"
        else
            x=0; [ -x "$full" ] && x=1
            sz=$(wc -c < "$full" | tr -d ' ')
            h=$(sha256_of "$full")
            printf 'file\t%s\t%s\t%s\t%s\n' "$p" "$x" "$sz" "$h"
        fi
    done
}

# materialize --cas C --dir D --plan P ; plan TSV: path<TAB>sha256<TAB>exec
cmd_materialize() {
    cas=""; dir=""; plan=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --cas) cas=$2; shift 2;;
            --dir) dir=$2; shift 2;;
            --plan) plan=$2; shift 2;;
            *) echo "materialize: unknown arg $1" >&2; exit 2;;
        esac
    done
    [ -f "$plan" ] || { echo "materialize: no plan" >&2; exit 2; }
    while IFS="$(printf '\t')" read -r path sha x; do
        [ -n "$path" ] || continue
        dest="$dir/$path"
        mkdir -p "$(dirname "$dest")"
        rm -f "$dest"
        if [ "$x" = "L" ]; then
            ln -s "$sha" "$dest"   # sha column carries the link target
            continue
        fi
        blob="$cas/$(echo "$sha" | cut -c1-2)/$sha"
        [ -f "$blob" ] || { echo "materialize: missing blob $sha for $path" >&2; exit 3; }
        if [ "$x" = "1" ]; then
            # copy, not link: chmod on a hardlink would flip the CAS inode
            cp "$blob" "$dest" && chmod +x "$dest"
        else
            ln "$blob" "$dest" 2>/dev/null || cp "$blob" "$dest"
        fi
    done < "$plan"
    echo '{"materialized": true}'
}

# ingest --cas C --root R --plan P ; plan TSV: path<TAB>sha256
# Links job outputs into the site CAS so later tasks chain without re-transfer.
cmd_ingest() {
    cas=""; root=""; plan=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --cas) cas=$2; shift 2;;
            --root) root=$2; shift 2;;
            --plan) plan=$2; shift 2;;
            *) echo "ingest: unknown arg $1" >&2; exit 2;;
        esac
    done
    [ -f "$plan" ] || { echo "ingest: no plan" >&2; exit 2; }
    while IFS="$(printf '\t')" read -r path sha; do
        [ -n "$path" ] || continue
        src="$root/$path"
        [ -f "$src" ] || { echo "ingest: missing output $path" >&2; exit 3; }
        blobdir="$cas/$(echo "$sha" | cut -c1-2)"
        blob="$blobdir/$sha"
        [ -f "$blob" ] && continue
        mkdir -p "$blobdir"
        ln "$src" "$blob.tmp.$$" 2>/dev/null || cp "$src" "$blob.tmp.$$"
        mv "$blob.tmp.$$" "$blob"
    done < "$plan"
    echo '{"ingested": true}'
}

# unpack-verify --archive A --sha256 H --dest D  (atomic: tmp + rename)
cmd_unpack_verify() {
    archive=""; sha=""; dest=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --archive) archive=$2; shift 2;;
            --sha256) sha=$2; shift 2;;
            --dest) dest=$2; shift 2;;
            *) echo "unpack-verify: unknown arg $1" >&2; exit 2;;
        esac
    done
    got=$(sha256_of "$archive")
    if [ "$got" != "$sha" ]; then
        echo "{\"ok\": false, \"error\": \"hash mismatch\", \"expected\": \"$sha\", \"got\": \"$got\"}"
        exit 4
    fi
    rm -rf "$dest.tmp"
    mkdir -p "$dest.tmp"
    tar -xf "$archive" -C "$dest.tmp"
    rm -rf "$dest"
    mv "$dest.tmp" "$dest"
    echo '{"ok": true}'
}

# load: what is realistically available right now (cheap; poll-safe)
cmd_load() {
    set +e
    cpus=$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
    l1=0; l5=0; l15=0
    if [ -r /proc/loadavg ]; then
        read -r l1 l5 l15 _ < /proc/loadavg
    else
        # darwin/BSD: vm.loadavg prints "{ 1.80 2.11 2.15 }"
        set -- $(sysctl -n vm.loadavg 2>/dev/null | tr -d '{}')
        [ $# -ge 3 ] && { l1=$1; l5=$2; l15=$3; }
    fi
    mem_avail_kb=$(awk '/MemAvailable/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
    if [ "${mem_avail_kb:-0}" -eq 0 ] && command -v vm_stat >/dev/null 2>&1; then
        # darwin: free + inactive + purgeable pages approximate "available"
        mem_avail_kb=$(vm_stat 2>/dev/null | awk -v ps="$(sysctl -n hw.pagesize 2>/dev/null || echo 4096)" \
            '/Pages free|Pages inactive|Pages purgeable/{gsub("\\.","",$NF); t+=$NF} END{print int(t*ps/1024)}')
    fi
    users=$(who 2>/dev/null | wc -l | tr -d ' ')
    # GPUs are often the limiting factor: report live utilization + memory
    gpu_load=$(nvidia-smi --query-gpu=utilization.gpu,memory.used,memory.total \
        --format=csv,noheader,nounits 2>/dev/null | \
        awk -F', *' '{printf "%s{\"util_pct\":%d,\"mem_used_mb\":%d,\"mem_total_mb\":%d}", sep, $1, $2, $3; sep=","}' || true)
    cat <<EOF
{"cpus": $cpus, "load1": ${l1:-0}, "load5": ${l5:-0}, "load15": ${l15:-0},
 "mem_available_gb": $((mem_avail_kb / 1048576)), "login_users": ${users:-0},
 "gpus": [${gpu_load:-}]}
EOF
}

cmd_version() { echo "{\"shim_version\": $WEFT_SHIM_VERSION}"; }

sub="${1:-}"
[ -n "$sub" ] || { echo "usage: weft-shim <probe|run|status|tail|head|hash-tree|materialize|unpack-verify|version>" >&2; exit 2; }
shift
case "$sub" in
    probe) cmd_probe "$@";;
    run) cmd_run "$@";;
    status) cmd_status "$@";;
    status-batch) cmd_status_batch "$@";;
    tail) cmd_tail "$@";;
    head) cmd_head "$@";;
    read-from) cmd_read_from "$@";;
    hash-tree) cmd_hash_tree "$@";;
    list-tree) cmd_list_tree "$@";;
    materialize) cmd_materialize "$@";;
    ingest) cmd_ingest "$@";;
    unpack-verify) cmd_unpack_verify "$@";;
    load) cmd_load "$@";;
    version) cmd_version "$@";;
    *) echo "weft-shim: unknown command $sub" >&2; exit 2;;
esac
